# --- Backend (FastAPI) ---
APP_NAME=Synapse3D
APP_ENV=development
DEBUG=true

# Supabase / PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/synapse3d

# JWT autentifikatsiya uchun (keyingi fazada ishlatiladi)
SECRET_KEY=change-this-to-a-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Realtime server (Node.js) ---
REALTIME_PORT=4000
REALTIME_URL=ws://localhost:4000

# --- Ollama (lokal LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:4000